[{
  "apiVersion" : "apps/v1",
  "kind" : "Deployment",
  "metadata" : {
    "annotations" : {
      "app.quarkus.io/quarkus-version" : "3.35.2",
      "app.quarkus.io/vcs-uri" : "https://github.com/rmortale/quarkus-jdbc-paramsource.git"
    },
    "labels" : {
      "app.kubernetes.io/name" : "quarkus-jdbc-paramsource",
      "app.kubernetes.io/managed-by" : "quarkus"
    },
    "name" : "quarkus-jdbc-paramsource"
  },
  "spec" : {
    "replicas" : 1,
    "selector" : {
      "matchLabels" : {
        "app.kubernetes.io/name" : "quarkus-jdbc-paramsource"
      }
    },
    "template" : {
      "metadata" : {
        "annotations" : {
          "app.quarkus.io/quarkus-version" : "3.35.2",
          "app.quarkus.io/vcs-uri" : "https://github.com/rmortale/quarkus-jdbc-paramsource.git"
        },
        "labels" : {
          "app.kubernetes.io/managed-by" : "quarkus",
          "app.kubernetes.io/name" : "quarkus-jdbc-paramsource"
        }
      },
      "spec" : {
        "containers" : [ {
          "env" : [ {
            "name" : "KUBERNETES_NAMESPACE",
            "valueFrom" : {
              "fieldRef" : {
                "fieldPath" : "metadata.namespace"
              }
            }
          } ],
          "envFrom" : [ {
            "secretRef" : {
              "name" : "artemis-secret"
            }
          }, {
            "secretRef" : {
              "name" : "postgres-secret"
            }
          } ],
          "image" : "ghcr.io/rmortale/quarkus-jdbc-paramsource:sha-dfe2ddb",
          "imagePullPolicy" : "Always",
          "name" : "quarkus-jdbc-paramsource"
        } ],
        "terminationGracePeriodSeconds" : 10
      }
    }
  }
}]